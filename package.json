{
  "name": "when2meet-better",
  "version": "0.1.0",
  "description": "A minimal, better-UX open-source when2meet clone on Cloudflare Workers",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:prod": "tsx scripts/migrate.ts --env prod",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "hono": "^4.6.0",
    "nanoid": "^5.0.0",
    "workers-og": "^0.0.25"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@playwright/test": "^1.59.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.80.0"
  }
}
